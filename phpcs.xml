<?xml version="1.0"?>
<ruleset name="Laravel Standard">
    <description>Laravel Coding Standard for PHP_CodeSniffer</description>
    
    <rule ref="PSR12"/>

    <file>app</file>
    <file>bootstrap</file>
    <file>config</file>
    <file>routes</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/public/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    
    <arg name="colors"/>
    <arg value="sp"/>
</ruleset>